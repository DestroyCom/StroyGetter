generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Video {
  id             String   @id @default(cuid(2))
  title          String
  url            String   @unique
  availableFiles File[]   
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
}

model File {
  id           String   @id @default(cuid(2))
  path         String   @unique
  hash         String   @unique        
  quality      String                 
  qualityLabel String                 
  videoId      String                
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}
